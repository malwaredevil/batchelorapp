modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "app-config-drift"

[[workflows.workflow]]
name = "app-config-drift"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run lint:config"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "google-calendar:1.0.0", "agentphone:1.0.0", "apify:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 20004
externalPort = 3002

[[ports]]
localPort = 22012
externalPort = 3001

[[ports]]
localPort = 22333
externalPort = 3000

[[ports]]
localPort = 25313
externalPort = 4200

[[ports]]
localPort = 25604
externalPort = 3003

[[ports]]
localPort = 25669
externalPort = 5000

